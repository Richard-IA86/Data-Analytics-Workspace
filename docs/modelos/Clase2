na lista\n","print(persona.keys())\n","\n","# metodo .values() nos devuelve los valores del diccionario dentro de una lista\n","print(persona.values())\n","valores = persona.values()\n","#metodo .items() nos devuelve una lista que contiene todos los pares de clave valor dentro de tuplas\n","#[('nombre', 'nicolas'), ('edad', 26), ('altura', 1.7), ('profesor', True), ('profesión', 'Ingeniera')])\n","print(persona.items())\n","\n","#metodo .pop() Elimina y devuelve el valor asociado a la clave especificada.\n","dato_eliminado = persona.pop(\"profesion\")\n","print(f\"dato eliminado: {dato_eliminado}\")\n","print(persona)\n","\n","#metodo popitem() Elimina y devuelve dentro de una tupla el último par clave-valor insertado.\n","dato_eliminado = persona.popitem()\n","print(f\"dato eliminado: {dato_eliminado}\")\n","print(persona)\n","\n","#metodo update() Actualiza el diccionario con pares clave-valor de otro diccionario o iterable.\n","dato = {\n","    \"profesion\" : \"ingenieria\",\n","    \"profesor\" : True\n","}\n","\n","persona.update(dato)\n","print(persona)\n","\n","persona.update({\"profesion\" : \"programador\"})\n","print(persona)\n","\n","#metodo setdefault() crea el nuevo par clave-valor solo si no existe\n","persona.setdefault(\"email\", \"no_asignado@correo.com\")\n","\n","# .copy(): hacemos una copia independiente\n","copia_usuario = persona.copy()\n","copia_usuario[\"usuario\"] = \"admin123\"\n","\n","#metodo clear() Elimina todos los elementos del diccionario, dejándolo vacío.\n","\n","dato.clear()\n","print(dato) # {}\n","\n","\n","#iteracion de diccionarios y como recorrerlos\n","    # Mostrar solo las claves\n","print(\"Claves:\")\n","for clave in persona.keys():\n","    print(clave)\n","\n","# Mostrar solo los valores\n","print(\"\\nValores:\")\n","for valor in persona.values():\n","    print(valor)\n","\n","for clave, valor in persona.items():\n","    print(f\"{clave}: {valor}\")\n","\n","\n","#Diccionarios anidados\n","estudiantes = {\n","    \"Ana\": {\"edad\": 22, \"carrera\": \"Informática\"},\n","    \"Juan\": {\"edad\": 24, \"carrera\": \"Diseño\"},\n","    \"Nico\": {\"edad\" : 28, \"carrera\": \"Python\"}\n","}\n","\n","print(estudiantes[\"Ana\"][\"carrera\"]) #Informática\n","\n","#Listas de diccionarios\n","inventario = [\n","    {\"nombre\": \"manzanas\", \"cantidad\": 50},\n","    {\"nombre\": \"peras\", \"cantidad\": 30},\n","    {\"nombre\": \"naranjas\", \"cantidad\": 40},\n","]\n","\n","print(inventario[0][\"nombre\"]) #manzanas\n","\n","for i in range(len(inventario)):\n","    print(f\"Nombre: {inventario[i][\"nombre\"]} con {inventario[i][\"cantidad\"]} unidades\")"],"metadata":{"id":"Spl0o9ROE3yi"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["#Conjuntos"],"metadata":{"id":"b5BcBGUhGopL"}},{"cell_type":"code","source":["mi_conjunto = {1, 2, 3, 3, 4} # Resulta en {1, 2, 3, 4}"],"metadata":{"id":"FbfZY0azGq74"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["#Funciones lambda"],"metadata":{"id":"GWo_kePeGxUl"}},{"cell_type":"code","source":["suma = lambda x, y: x + y\n","print(suma(2,3))\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"2vP0L8-QGwcj","executionInfo":{"status":"ok","timestamp":1774997754729,"user_tz":180,"elapsed":120,"user":{"displayName":"Nicolas Riquelme","userId":"07887000495658721645"}},"outputId":"36d30d1f-6e4b-46e9-efdf-7f7e7895c194"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["5\n"]}]},{"cell_type":"markdown","source":["#List Comprehension"],"metadata":{"id":"6NYoA885HK6e"}},{"cell_type":"code","source":["cuadrados = [x**2 for x in range(10)]\n","print(cuadrados)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ni3OfkLLHMhD","executionInfo":{"status":"ok","timestamp":1774997843187,"user_tz":180,"elapsed":92,"user":{"displayName":"Nicolas Riquelme","userId":"07887000495658721645"}},"outputId":"a39dfe47-8473-404a-c00c-fea3f2856f04"},"execution_cou